APP_ENV=dev
APP_NAME=FitMiniApp Production
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true
SECRET_KEY=change-me-super-secret
ACCESS_TOKEN_EXPIRE_MINUTES=60
REFRESH_TOKEN_EXPIRE_DAYS=30
DATABASE_URL=postgresql+psycopg://fitminiapp:fitminiapp@db:5432/fitminiapp
ENABLE_DEV_AUTH=true
DEV_DEFAULT_USER_ID=1001
FRONTEND_BASE_URL=http://localhost:8000
BOT_TOKEN=replace-me
TELEGRAM_BOT_TOKEN=replace-me
TELEGRAM_BOT_USERNAME=fitminiapp_bot
PAYMENT_PROVIDER=mock
PAYMENT_PUBLIC_URL=http://localhost:8000
WORKER_POLL_SECONDS=10
